    </body>
    <script>
    // Performance Chart - All Grades
    const ctxPerformance = document.getElementById('performanceChart').getContext('2d');
    const performanceChart = new Chart(ctxPerformance, {
      type: 'bar',
      data: {
        labels: ['EVS/Science 6', 'India Awareness 6', 'Math 6', 'Reading 6', 'EVS/Science 7', 'India Awareness 7', 'Math 7', 'Reading 7', 'EVS/Science 8', 'India Awareness 8', 'Math 8', 'Reading 8'],
        datasets: [{
          label: 'School Average',
          data: [41.67, 36.67, 34.89, 41.86, 42.3, 32.85, 37.68, 37.15, 54.58, 33.86, 50.75, 41.06],
          backgroundColor: 'rgba(54, 162, 235, 0.8)',
          order: 1
        }, {
          label: 'Test Average',
          data: [55.33, 44.52, 42.99, 53.17, 54.75, 42.37, 47.65, 49.32, 60.77, 38.22, 54.07, 48.42],
          borderColor: 'rgba(255, 99, 132, 1)',
          backgroundColor: 'rgba(255, 99, 132, 0.2)',
          type: 'line',
          borderWidth: 2,
          order: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        scales: { 
          y: { 
            beginAtZero: true, 
            max: 100, 
            title: { 
              display: true, 
              text: 'Percentage (%)' 
            } 
          },
          x: {
            ticks: {
              autoSkip: false,
              maxRotation: 45,
              minRotation: 45
            }
          }
        },
        plugins: {
          legend: {
            display: true,
            position: 'top'
          }
        }
      }
    });

    // Radar Chart 1 - Grade 6 Overall Performance
    const ctxRadar1 = document.getElementById('radarChart1').getContext('2d');
    const radarChart1 = new Chart(ctxRadar1, {
      type: 'radar',
      data: {
        labels: ['EVS/Science', 'India Awareness', 'Math', 'Reading'],
        datasets: [{
          label: 'School Average',
          data: [41.67, 36.67, 34.89, 41.86],
          backgroundColor: 'rgba(54, 162, 235, 0.2)',
          borderColor: 'rgba(54, 162, 235, 1)',
          borderWidth: 2,
          pointRadius: 4,
          pointHoverRadius: 6
        }, {
          label: 'Test Average',
          data: [55.33, 44.52, 42.99, 53.17],
          backgroundColor: 'rgba(255, 99, 132, 0.2)',
          borderColor: 'rgba(255, 99, 132, 1)',
          borderWidth: 2,
          pointRadius: 4,
          pointHoverRadius: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        scales: {
          r: {
            beginAtZero: true,
            max: 60,
            ticks: {
              stepSize: 10,
              callback: function(value) { return value + '%'; },
              font: {
                size: 10
              }
            },
            pointLabels: {
              font: {
                size: 11
              }
            }
          }
        },
        plugins: {
          legend: {
            display: true,
            position: 'top'
          }
        }
      }
    });

    // Grade 6 Chart - Exact replica from file 2
    const ctx6 = document.getElementById('grade6Chart').getContext('2d');
    const grade6Chart = new Chart(ctx6, {
      type: 'bar',
      data: {
        labels: ['EVS/Science', 'India\nAwareness', 'Math', 'Reading'],
        datasets: [{
          label: 'School_Average',
          data: [41.67, 36.67, 34.89, 41.86],
          backgroundColor: '#4472C4',
          borderColor: '#4472C4',
          borderWidth: 1,
          barThickness: 60,
          order: 2
        }, {
          label: 'Test_Average',
          data: [55.33, 44.52, 42.99, 53.17],
          type: 'line',
          borderColor: '#C65911',
          backgroundColor: '#C65911',
          borderWidth: 3,
          pointRadius: 5,
          pointBackgroundColor: '#C65911',
          pointBorderColor: '#C65911',
          pointHoverRadius: 6,
          tension: 0,
          order: 1,
          datalabels: {
            align: 'top',
            anchor: 'end',
            font: {
              size: 11,
              weight: 'normal'
            },
            formatter: function(value) {
              return value.toFixed(2) + '%';
            }
          }
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        aspectRatio: 1.8,
        plugins: {
          legend: {
            display: false
          },
          tooltip: {
            enabled: true
          },
          datalabels: {
            display: function(context) {
              return context.datasetIndex === 1; // Only show for line
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            max: 60,
            ticks: {
              stepSize: 10,
              callback: function(value) {
                return value.toFixed(2) + '%';
              },
              font: {
                size: 10
              }
            },
            title: {
              display: true,
              text: 'Axis Title',
              font: {
                size: 11
              }
            },
            grid: {
              display: true,
              color: '#E0E0E0'
            }
          },
          x: {
            grid: {
              display: false
            },
            ticks: {
              font: {
                size: 11
              }
            }
          }
        },
        layout: {
          padding: {
            top: 20,
            right: 10,
            bottom: 10,
            left: 10
          }
        }
      },
      plugins: [ChartDataLabels]
    });

    // Competency Radar Chart - Grade 6
    const ctxCompetency = document.getElementById('competencyRadarChart').getContext('2d');
    const competencyRadarChart = new Chart(ctxCompetency, {
      type: 'radar',
      data: {
        labels: ['6.C-1.2', '6.C-1.4', '6.C-2.1', '6.C-2.2', '6.C-2.5', '6.C-3.1', '6.C-3.2', '6.C-3.3', '6.C-4.1', '6.C-4.2', '6.C-4.3', '6.C-5.1', '6.C-5.2', '6.C-6.1', '6.C-6.2', '6.C-7.1', '6.C-8.1', '6.C-9.1', '6.C-9.2'],
        datasets: [{
          label: 'Average of School Competency',
          data: [33.61, 45.00, 30.00, 31.11, 39.17, 53.89, 40.00, 28.33, 51.67, 54.52, 47.08, 43.33, 43.33, 26.67, 32.50, 41.67, 34.17, 40.42, 46.67],
          backgroundColor: 'rgba(54, 162, 235, 0.2)',
          borderColor: 'rgba(54, 162, 235, 1)',
          borderWidth: 2,
          pointRadius: 3,
          pointHoverRadius: 5
        }, {
          label: 'Average of Test Competency',
          data: [49.53, 49.24, 49.86, 41.91, 44.12, 69.12, 44.31, 53.06, 55.19, 68.37, 59.90, 65.87, 61.08, 50.30, 46.32, 56.95, 54.04, 47.10, 48.57],
          backgroundColor: 'rgba(255, 99, 132, 0.2)',
          borderColor: 'rgba(255, 99, 132, 1)',
          borderWidth: 2,
          pointRadius: 3,
          pointHoverRadius: 5
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        scales: {
          r: {
            beginAtZero: true,
            max: 75,
            ticks: {
              stepSize: 15,
              callback: function(value) { return value + '%'; },
              font: {
                size: 9
              }
            },
            pointLabels: {
              font: {
                size: 9
              }
            }
          }
        },
        plugins: {
          legend: {
            display: true,
            position: 'top',
            labels: {
              font: {
                size: 11
              }
            }
          }
        }
      }
    });
  </script>
